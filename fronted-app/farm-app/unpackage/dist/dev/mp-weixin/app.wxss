/* 基础网格系统 */
.grid {
    display: grid;
}
.grid-cols-1 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
}
.grid-cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}
.grid-cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
}
.grid-cols-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
}
/* 响应式网格 (兼容微信小程序) */
@media (min-width: 768px) {
.md-grid-cols-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
}
.md-grid-cols-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
}
.md-grid-cols-4 {
        grid-template-columns: repeat(4, minmax(0, 1fr));
}
.md-flex-row {
        flex-direction: row;
}
.md-w-1-4 {
        width: 25%;
}
.md-w-1-2 {
        width: 50%;
}
.md-w-3-4 {
        width: 75%;
}
}
@media (min-width: 1024px) {
.lg-grid-cols-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
}
.lg-grid-cols-4 {
        grid-template-columns: repeat(4, minmax(0, 1fr));
}
.lg-flex-row {
        flex-direction: row;
}
.lg-w-1-4 {
        width: 25%;
}
.lg-w-3-4 {
        width: 75%;
}
}
/* 常用宽度 (兼容微信小程序) */
.w-1-2 {
    width: 50%;
}
.w-1-3 {
    width: 33.333333%;
}
.w-2-3 {
    width: 66.666667%;
}
.w-1-4 {
    width: 25%;
}
.w-3-4 {
    width: 75%;
}
.w-1-5 {
    width: 20%;
}
.w-2-5 {
    width: 40%;
}
.w-3-5 {
    width: 60%;
}
.w-4-5 {
    width: 80%;
}
.w-full {
    width: 100%;
}
/* 容器类 (兼容微信小程序) */
.container {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
}
@media (min-width: 640px) {
.container {
        max-width: 640px;
}
}
@media (min-width: 768px) {
.container {
        max-width: 768px;
}
}
@media (min-width: 1024px) {
.container {
        max-width: 1024px;
}
}
@media (min-width: 1280px) {
.container {
        max-width: 1280px;
}
}
/* 常用间距 (兼容微信小程序) */
.gap-1 {
    gap: 0.25rem;
}
.gap-2 {
    gap: 0.5rem;
}
.gap-4 {
    gap: 1rem;
}
.gap-6 {
    gap: 1.5rem;
}
.gap-8 {
    gap: 2rem;
}
/* 间距辅助类 (兼容微信小程序) */
.space-x-2>view+view,
.space-x-2>text+text {
    margin-left: 0.5rem;
}
.space-x-4>view+view,
.space-x-4>text+text {
    margin-left: 1rem;
}
.space-y-2>view+view,
.space-y-2>text+text {
    margin-top: 0.5rem;
}
.space-y-4>view+view,
.space-y-4>text+text {
    margin-top: 1rem;
}
.space-y-8>view+view,
.space-y-8>text+text {
    margin-top: 2rem;
}
/* 响应式辅助类 (兼容微信小程序) */
@media (min-width: 768px) {
.md-flex-row {
        flex-direction: row;
}
.md-items-center {
        align-items: center;
}
.md-justify-between {
        justify-content: space-between;
}
.md-space-x-4>view+view {
        margin-left: 1rem;
}
.md-space-y-0>view+view {
        margin-top: 0;
}
.md-block {
        display: block;
}
.md-hidden {
        display: none;
}
}
/* 交互状态类 (兼容微信小程序，建议配合 hover-class 使用) */
.hover-bg-gray-50:active {
    background-color: #f9fafb;
}
.hover-bg-gray-100:active {
    background-color: #f3f4f6;
}
.hover-text-green-700:active {
    color: #15803d;
}
.hover-text-blue-700:active {
    color: #1d4ed8;
}
/* 焦点状态类 (微信小程序建议使用 focus 伪类) */
.focus-ring-2:focus {
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.5);
}
.focus-ring-blue-500:focus {
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.5);
}
