<view class="cart-page min-h-screen bg-gray-50"><view class="bg-white shadow-sm py-4"><view class="container mx-auto px-4"><text class="text-3xl font-bold">购物车</text><text class="text-gray-600 block mt-2">管理您的采购商品</text></view></view><view class="container mx-auto px-4 py-8"><view wx:if="{{a}}" class="text-center py-16"><text class="text-5xl mb-4">🛒</text><text class="text-2xl font-bold text-gray-700 block mb-4">购物车空空如也</text><text class="text-gray-600 block mb-8">快去添加心仪的商品吧！</text><button bindtap="{{b}}" class="px-8 py-3 bg-green-600 text-white rounded-lg hover-bg-green-700 font-medium"> 去逛逛 </button></view><view wx:else class="flex flex-col lg-flex-row gap-8"><view class="lg-w-2-3"><view class="bg-white rounded-xl shadow-sm p-4 mb-4"><label class="flex items-center"><input type="checkbox" class="h-5 w-5 text-green-600 focus-ring-green-500 border-gray-300 rounded" checked="{{c}}" bindchange="{{d}}"/><text class="ml-3 font-medium">全选 ({{e}}/{{f}})</text></label></view><view class="space-y-4"><view wx:for="{{g}}" wx:for-item="item" wx:key="l" class="bg-white rounded-xl shadow-sm p-4"><view class="flex items-start gap-4"><label class="flex items-start"><input type="checkbox" class="h-5 w-5 text-green-600 focus-ring-green-500 border-gray-300 rounded mt-1" checked="{{item.a}}" bindchange="{{item.b}}"/></label><view class="flex-1"><view class="flex items-start justify-between"><view><text class="font-bold text-lg block mb-1">{{item.c}}</text><text class="text-gray-600 text-sm block">{{item.d}}</text><text class="text-gray-600 text-sm block">{{item.e}}</text></view><button bindtap="{{item.f}}" class="text-gray-400 hover-text-red-500"> ? </button></view><view class="flex items-center justify-between mt-4"><text class="text-green-700 font-bold text-xl">¥{{item.g}}</text><view class="flex items-center space-x-4"><view class="flex items-center border border-gray-300 rounded-lg"><button bindtap="{{item.h}}" class="px-3 py-1 text-gray-600 hover-bg-gray-100" disabled="{{item.i}}"> - </button><text class="px-4 py-1">{{item.j}}</text><button bindtap="{{item.k}}" class="px-3 py-1 text-gray-600 hover-bg-gray-100"> + </button></view></view></view></view></view></view></view></view><view class="lg-w-1-3"><view class="bg-white rounded-xl shadow-sm p-6 sticky top-8"><text class="text-2xl font-bold mb-6 block">订单摘要</text><view class="space-y-4 mb-6"><view class="flex justify-between"><text class="text-gray-600">商品总价</text><text class="font-medium">¥{{h}}</text></view><view class="flex justify-between"><text class="text-gray-600">运费</text><text class="font-medium">¥{{i}}</text></view><view class="flex justify-between"><text class="text-gray-600">优惠</text><text class="text-green-600 font-medium">-¥{{j}}</text></view><view class="border-t pt-4 flex justify-between"><text class="text-lg font-bold">合计</text><text class="text-2xl font-bold text-green-700">¥{{k}}</text></view></view><button bindtap="{{m}}" disabled="{{n}}" class="{{['w-full', 'py-4', 'bg-green-600', 'text-white', 'rounded-lg', 'hover-bg-green-700', 'font-bold', 'text-lg', 'mb-4', o]}}"> 去结算 ({{l}}件商品) </button><view class="text-sm text-gray-600 space-y-2"><text class="block">√ 全场满 ¥5000 包邮</text><text class="block">√ 支持对公转账、线上支付</text><text class="block">√ 7天无理由退货</text></view></view><view class="bg-white rounded-xl shadow-sm p-6 mt-6"><text class="font-bold mb-4 block">优惠券</text><view class="space-y-3"><view wx:for="{{p}}" wx:for-item="coupon" wx:key="d" class="flex items-center justify-between p-3 border rounded-lg"><view><text class="font-medium block">{{coupon.a}}</text><text class="text-sm text-gray-600">{{coupon.b}}</text></view><button bindtap="{{coupon.c}}" class="px-4 py-1 border border-green-600 text-green-600 rounded hover-bg-green-50"> 使用 </button></view></view></view></view></view></view></view>